# Badger — secrets template
# 1. Copy this file to  .streamlit/secrets.toml
# 2. Fill in your real values
# 3. NEVER commit secrets.toml to git (it's for your eyes only)

# ── Google Sheets service account ───────────────────────────────
# Paste the contents of the JSON key you download from Google Cloud Console.
[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit"
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
client_email = "badger-bot@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/badger-bot%40your-project-id.iam.gserviceaccount.com"

# ── Slack ───────────────────────────────────────────────────────
[slack]
bot_token = "xoxb-your-bot-user-oauth-token"
default_channel = "#badger-test"   # where the "Test Badger Connection" message goes

# ── Google Calendar (optional) ──────────────────────────────────
# Uses the SAME service-account key as [connections.gsheets] above.
# mode = "shared"    -> each calendar below is shared with the bot email
# mode = "delegated" -> service account has domain-wide delegation (Workspace
#                       admin); Badger impersonates each email's 'primary' calendar
# calendars: list of calendar IDs (usually team emails). Empty = whole team
#            (every email in the organigram).
[google_calendar]
enabled = false
mode = "shared"
calendars = ["chris@tandw.co.za", "jack@tandw.co.za"]
